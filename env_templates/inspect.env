###############################################
# Inspect Agents — Centralized Environment
#
# Copy this file or point to it with:
#   uv run python examples/inspect/run.py --env-file env_templates/inspect.env "..."
# or export:
#   export INSPECT_ENV_FILE=env_templates/inspect.env
#
# Values in this file act as defaults. They will NOT override values set in:
# - real environment variables
# - repo root .env
# - examples/inspect/.env (legacy)
###############################################

## Providers & Models
#
# Explicit model wins and avoids provider ambiguity. If you prefer a different
# backend, comment this out and use DEEPAGENTS_MODEL_PROVIDER + <PROVIDER>_MODEL
# below. Do NOT set INSPECT_EVAL_MODEL=none/none here — that sentinel disables
# the override and will require every task/agent to pass a model explicitly.
INSPECT_EVAL_MODEL=ollama/llama3.1:8b

# Provider selection (used when INSPECT_EVAL_MODEL is not set)
# One of: ollama | lm-studio | openai | anthropic | ...
DEEPAGENTS_MODEL_PROVIDER=ollama

# Role mapping (optional; examples — uncomment and customize)
# INSPECT_ROLE_GRADER_PROVIDER=openai
# INSPECT_ROLE_GRADER_MODEL=gpt-4o-mini
# INSPECT_ROLE_RESEARCHER_PROVIDER=ollama
# INSPECT_ROLE_RESEARCHER_MODEL=llama3.1:8b

# Ollama (local)
OLLAMA_MODEL_NAME=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (OpenAI-compatible local server).
# Uncomment the three lines below and set DEEPAGENTS_MODEL_PROVIDER=lm-studio
# if you prefer LM Studio instead of Ollama.
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL_NAME=local-model
# LM_STUDIO_API_KEY=lm-studio

# Remote providers (set when using non-local providers)
# OPENAI_API_KEY=
# OPENAI_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# GOOGLE_API_KEY=
# GOOGLE_MODEL=
# GROQ_API_KEY=
# GROQ_MODEL=
# MISTRAL_API_KEY=
# MISTRAL_MODEL=
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=
# FIREWORKS_API_KEY=
# FIREWORKS_MODEL=
# GROK_API_KEY=
# GROK_MODEL=
# GOODFIRE_API_KEY=
# GOODFIRE_MODEL=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Web Search (pick one external provider)
# Tavily (recommended for simplicity)
TAVILY_API_KEY=

# Google Custom Search Engine (alternative to Tavily)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=

# Tool Toggles
# INSPECT_ENABLE_THINK=1
# Enable web search tools automatically when keys are present
INSPECT_ENABLE_WEB_SEARCH=1
# INSPECT_ENABLE_EXEC=0
# INSPECT_ENABLE_WEB_BROWSER=0
# INSPECT_ENABLE_TEXT_EDITOR_TOOL=0
# Optional: prefer internal provider for web search augmentation
# INSPECT_WEB_SEARCH_INTERNAL=openai  # or anthropic|perplexity|gemini|grok

## Approvals & Presets
# INSPECT_APPROVAL_PRESET=dev   # one of: ci|dev|prod (ignored when code supplies approval policies)

## Parallel Tool Execution (Kill‑Switch)
# INSPECT_DISABLE_TOOL_PARALLEL=1   # force serial approval for non‑handoff tools
# INSPECT_TOOL_PARALLELISM_DISABLE=1  # legacy alias (supported; prefer INSPECT_DISABLE_TOOL_PARALLEL)

## Filesystem & Sandbox (Mode, Safety, Limits)
# Inspect Agents behavior
# Use 'store' (default) for in-memory virtual FS, or 'sandbox' to route
# file operations to Inspect's host text editor tool (requires sandbox setup).
INSPECT_AGENTS_FS_MODE=store

# Sandbox read-only mode: when FS_MODE=sandbox and this flag is truthy (1/true),
# write/edit/delete are blocked (tools raise ToolException "SandboxReadOnly" and
# log a tool_event error). Listing/reading remain allowed. No effect in store mode.
# INSPECT_AGENTS_FS_READ_ONLY=1

# Advanced FS settings
# INSPECT_SANDBOX_PREFLIGHT=auto           # auto|skip|force
# INSPECT_SANDBOX_PREFLIGHT_TTL_SEC=300    # cache TTL for preflight result
# INSPECT_SANDBOX_LOG_PATHS=0              # 1 to log fs_root/tool in warnings
# INSPECT_AGENTS_FS_ROOT=/repo             # absolute root for sandbox confinement
# INSPECT_AGENTS_FS_MAX_BYTES=5000000      # per-file byte ceiling (OOM guard)
# INSPECT_AGENTS_TOOL_TIMEOUT=15           # default tool timeout in seconds
# INSPECT_AGENTS_TYPED_RESULTS=1           # return typed result models from tools

## Retries & Backoff (Model generate)
# INSPECT_RETRY_DISABLE_TENACITY=1
# INSPECT_RETRY_MAX_ATTEMPTS=3
# INSPECT_RETRY_INITIAL_SECONDS=0.01
# INSPECT_RETRY_MAX_SECONDS=0.02
# INSPECT_RETRY_JITTER=0

## Iterative Agent (time/step/prune/truncation)
# INSPECT_ITERATIVE_TIME_LIMIT=60     # seconds; non‑positive disables
# INSPECT_ITERATIVE_MAX_STEPS=10      # steps; non‑positive disables
# INSPECT_PRUNE_AFTER_MESSAGES=120    # prune tail after this many messages; <=0 disables
# INSPECT_PRUNE_KEEP_LAST=40          # tail size to retain during pruning
# INSPECT_PER_MSG_TOKEN_CAP=0         # per-message token cap (approx); unset/0 disables
# INSPECT_TRUNCATE_LAST_K=200         # keep last K messages during token-aware truncation
# INSPECT_PRODUCTIVE_TIME=1           # subtract provider backoff from wall time where supported

## Runner Time‑Limit Telemetry
# INSPECT_LIMIT_NEARING_THRESHOLD=0.8  # fraction in (0,1) for early near‑limit event

## Logging & Observability
# Transcript output directory
INSPECT_LOG_DIR=.inspect/logs/
# Truncate long string fields in tool logs (chars)
# INSPECT_TOOL_OBS_TRUNCATE=200
# Optional Inspect trace file (for reviews/demos)
# INSPECT_TRACE_FILE=logs/inspect_ai/trace.log

## Tool Output & Truncation
# INSPECT_MAX_TOOL_OUTPUT=16384   # bytes; 0 disables; lower precedence than per‑call/config

# Quarantine / Handoff Filters (repo-wide defaults with per-agent overrides)
#
# Controls how conversation history is filtered when handing off to sub‑agents.
#
# Mode:
#   - strict (default): remove tools/system, keep only the last boundary message.
#   - scoped: strict + append a small JSON summary of current Todos/Files.
#   - off: identity (no filtering) — only use for debugging.
#
# Global default (applies when no explicit per-agent config or inheritance):
# INSPECT_QUARANTINE_MODE=strict
#
# Inheritance (cascade parent filter to nested handoffs):
#   1 (default) = inherit; 0 = do not inherit. When inheritance is enabled and a
#   parent active filter exists, the global default will NOT override it.
# INSPECT_QUARANTINE_INHERIT=1
#
# Per-agent override (wins over inheritance/global). The <agent> suffix is
# normalized to lower-case; non-alphanumeric → underscore; multiple underscores
# collapsed; trimmed at ends. Examples:
#   INSPECT_QUARANTINE_MODE__researcher=scoped
#   INSPECT_QUARANTINE_MODE__research_assistant_v2=strict  # from "Research Assistant v2"
#
# Scoped summary size guards (only when mode=scoped):
# INSPECT_SCOPED_MAX_BYTES=2048
# INSPECT_SCOPED_MAX_TODOS=10
# INSPECT_SCOPED_MAX_FILES=20

# Per-agent handoff limits (env)
#
# Set time/message/token budgets for specific sub-agents without editing code.
# Agent name normalization: lowercase; non-alphanumeric → _; repeated underscores collapsed.
# Examples:
# INSPECT_LIMIT_TIME__researcher=60        # seconds budget for researcher
# INSPECT_LIMIT_MESSAGES__writer=8         # message budget for writer
# INSPECT_LIMIT_TOKENS__grader=6000        # token budget for grader

## Cache
# UV_CACHE_DIR=.uv-cache

## Test / CI Knobs (optional for local runs)
# CI=1
# NO_NETWORK=1
# PYTEST_ADDOPTS="--maxfail=1 -q"
